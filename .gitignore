# =============================================================================
# DNS Monitor — .gitignore
# =============================================================================

# ── Segredos e configuração local ────────────────────────────────────────────
# NUNCA versionar — contém senhas, tokens e IPs internos
backend/.env
agent/agent.conf
agent/env
agent/.env
agent/.env.*

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python

# Virtualenvs
agent/venv/
backend/venv/
venv/
.venv/
env/

# Distribuição / build
dist/
build/
*.egg-info/
*.egg

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc

# mypy / type checkers
.mypy_cache/
.dmypy.json

# ── Docker ───────────────────────────────────────────────────────────────────
# Dados persistidos localmente pelos volumes
backend/grafana-data/
backend/pgdata/

# ── Grafana ──────────────────────────────────────────────────────────────────
# Banco interno do Grafana (gerado em runtime)
grafana/grafana.db
grafana/data/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
/var/log/

# ── Sistema operacional ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Editores e IDEs ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.bak

# ── Temporários ───────────────────────────────────────────────────────────────
*.tmp
*.temp
/tmp/
# Artefato do auto-update do agente (download intermediario antes do swap atomico).
# Glob *.tmp NAO cobre porque a extensao real e .update_tmp.
*.update_tmp

# ── Outros ───────────────────────────────────────────────────────────────────
DBA*.sql
runtests.txt
updatedash.txt
# Dataset de mock pra desenvolvimento local (nao versionar — pode conter
# hostnames/dados de cliente reais usados em reproducao de bug).
backend/mock_data.sql

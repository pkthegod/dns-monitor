# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
#
# IMPORTANTE: nao use @ # / ? % nas senhas — o parser do postgres quebra
# Para gerar secrets fortes:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

# ==== Ambiente ================================================
# production = ativa hard-fails de seguranca (Bearer admin, secrets minimo 32B)
# vazio/dev  = libera fallbacks pra desenvolvimento local
INFRA_VISION_ENV=production

# ==== PostgreSQL =============================================
POSTGRES_USER=dnsmonitor
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=dns_monitor
# 'disable' (default — DB no mesmo host docker), 'require' (DB externo TLS),
# 'verify-full' (DB externo com cert validado)
DB_SSL=disable

# ==== Backend API ============================================
# Token compartilhado entre backend e agentes (gere com token_hex)
AGENT_TOKEN=TROQUE_POR_TOKEN_SEGURO

# ==== Sessoes (cookies admin/cliente) =========================
# Minimo 32 bytes; em INFRA_VISION_ENV=production, falta = startup fail
ADMIN_SESSION_SECRET=
CLIENT_SESSION_SECRET=
# Rotacao sem downtime: durante a transicao, mantenha o secret antigo aqui
# (cookies emitidos com o secret anterior continuam validos por 1 ciclo de TTL)
# ADMIN_SESSION_SECRET_PREV=
# CLIENT_SESSION_SECRET_PREV=

# Cookie secure flag — TRUE em prod (exige HTTPS na borda); FALSE em dev local HTTP
COOKIE_SECURE=true

# ==== Painel Admin (superadmin via env) =======================
# Login emergencial — sobrepoe DB. Em prod, prefira criar admin_users
# (POST /api/v1/admin-users) e deixar estes em branco.
ADMIN_USER=admin
ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE

# ==== Bearer admin fallback (curl/tooling) ====================
# DUAS opcoes; em INFRA_VISION_ENV=production exige UMA das duas:
#
# Opcao A: range autorizado (ex: rede do operador)
# ADMIN_BEARER_ALLOWED_IPS=10.0.0.0/24,177.X.X.X
#
# Opcao B: rejeita todo Bearer admin (somente cookies via /admin/login)
ADMIN_BEARER_DISABLED=true

# ==== Proxy reverso (nginx + Cloudflare) =====================
# Lista de IPs/CIDRs do nginx imediato (NAO da CF). Sem isso, request.client.host
# = IP do nginx => rate-limit e audit cegos.
# Tipico:
#   - 127.0.0.1     se nginx no host e backend escuta em 8000
#   - 172.20.0.1    se nginx em outro container do mesmo bridge
TRUSTED_PROXIES=127.0.0.1

# Mesma lista, mas pro uvicorn confiar em X-Forwarded-Proto (cookies secure)
FORWARDED_ALLOW_IPS=127.0.0.1

# Hosts autorizados em CSRF (sem schema, sem porta, separados por virgula).
# Backend ja aceita o proprio Host header automaticamente; isso e pra hosts EXTRAS
# (ex: dominio antigo durante migracao, dominio interno alem do publico CF)
ALLOWED_ORIGINS=nsmonitor.procyontecnologia.net

# ==== NATS (mensageria) — Onda 1 P4 account isolation =========
# Backend e agentes usam creds DIFERENTES com permissions isoladas
# no nats-server.conf:
#   - NATS_BACKEND_USER/PASS: full access (publica/subscreve qualquer subject)
#   - NATS_AGENT_USER/PASS:   scoped — so publica acks/stats e subscreve comandos
# Atacante com creds dos agentes NAO consegue sequestrar comandos pra outros
# hosts (publish em dns.commands.<host> bloqueado pra esse user).
#
# NOVO DEPLOY (recomendado): gere 4 secrets distintos com:
#   python3 -c "import secrets; print(secrets.token_hex(16))"
NATS_BACKEND_USER=infra-vision-backend
NATS_BACKEND_PASS=
NATS_AGENT_USER=dnsmonitor
NATS_AGENT_PASS=
#
# MIGRATION DE DEPLOY EXISTENTE:
# Se voce ja tem agentes em prod usando NATS_USER/NATS_PASS, deixe as 4
# vars acima EM BRANCO e mantenha as legadas — docker-compose usa elas
# como fallback automatico tanto pro backend quanto pro AGENT user. Nada
# muda no agent.toml dos agentes; eles continuam autenticando, mas agora
# com permissions scoped no servidor (nao podem mais publicar dns.commands.*).
#
# Apos validar em prod, transicione gradualmente pra creds distintas:
#   1. Gere NATS_BACKEND_USER/PASS distintos do NATS_USER atual
#   2. Restart backend (so backend troca; agentes continuam no NATS_USER)
#   3. Eventualmente, gere NATS_AGENT_USER/PASS novos + faca rolling
#      restart dos agentes pra puxar
NATS_USER=dnsmonitor
NATS_PASS=TROQUE_POR_SENHA_NATS

# ==== Geolocate (mapa do dig_trace) ===========================
# ip-api.com — opcional. Vazio = HTTP free (IPs do trace em plaintext).
# Setado = HTTPS via pro.ip-api.com (transporte cifrado, ~$13/mes em
# https://members.ip-api.com). Recomendado em prod.
# IPAPI_KEY=

# ==== Telegram ================================================
# Crie um bot em @BotFather e obtenha o token
TELEGRAM_BOT_TOKEN=
# ID do chat/grupo que recebera os alertas
# Obtenha com: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ==== SMTP (email mensal opcional) ============================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

# ==== Grafana =================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=TROQUE_POR_SENHA_FORTE

# ==== Seguranca (deteccao automatica de IPs maliciosos) =======
# Desabilita bloqueio automatico de IPs (use so em dev)
# SECURITY_ENABLED=false
# IPs que nunca sao bloqueados (ex: rede do operador)
# SECURITY_WHITELIST=177.104.180.107,10.0.0.1

# ==== Webhooks externos (CRUD per-cliente) ====================
# Em dev/test: liberar webhooks pra hosts privados (localhost:6379, etc)
# NUNCA setar em prod — quebra protecao SSRF
# INFRA_VISION_ALLOW_PRIVATE_WEBHOOKS=true

# ==== Thresholds de alertas (opcionais) =======================
# THRESH_CPU_WARNING=80
# THRESH_CPU_CRITICAL=95
# THRESH_RAM_WARNING=85
# THRESH_RAM_CRITICAL=95
# THRESH_DISK_WARNING=80
# THRESH_DISK_CRITICAL=90
# THRESH_DNS_LATENCY_WARNING=200
# THRESH_DNS_LATENCY_CRITICAL=1000
# THRESH_OFFLINE_MINUTES=10

# ==== Observability (Fase B) ==================================
# Threshold em ms para logar slow request (default 1000)
# SLOW_REQUEST_THRESHOLD_MS=1000

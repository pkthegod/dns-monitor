{
  "title": "DNS Monitor — Visão Geral",
  "uid": "dns-overview",
  "tags": ["dns-monitor"],
  "timezone": "America/Sao_Paulo",
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Agentes Online",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) FROM v_agent_current_status WHERE agent_status = 'online'",
        "format": "table"
      }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",   "value": 0 },
            { "color": "green", "value": 1 }
          ]}
        }
      }
    },

    {
      "id": 2,
      "title": "Agentes Offline",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) FROM v_agent_current_status WHERE agent_status IN ('offline','never_seen')",
        "format": "table"
      }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 },
            { "color": "red",   "value": 1 }
          ]}
        }
      }
    },

    {
      "id": 3,
      "title": "Alertas Abertos",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT COUNT(*) FROM alerts_log WHERE resolved_at IS NULL",
        "format": "table"
      }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": 0 },
            { "color": "yellow", "value": 1 },
            { "color": "red",    "value": 5 }
          ]}
        }
      }
    },

    {
      "id": 4,
      "title": "Taxa de Sucesso DNS (última hora)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN success THEN 1 ELSE 0 END) / COUNT(*), 1) AS pct FROM dns_checks WHERE ts > NOW() - INTERVAL '1 hour'",
        "format": "table"
      }],
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": 0   },
            { "color": "yellow", "value": 90  },
            { "color": "green",  "value": 99  }
          ]}
        }
      }
    },

    {
      "id": 10,
      "title": "Status dos Agentes",
      "type": "table",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT hostname, display_name, location, agent_status, cpu_percent, ram_percent, dns_service_name, dns_service_active, last_seen FROM v_agent_current_status ORDER BY agent_status DESC, hostname",
        "format": "table"
      }],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "agent_status" },
            "properties": [{
              "id": "custom.displayMode", "value": "color-background"
            }, {
              "id": "mappings", "value": [
                { "type": "value", "options": { "online":     { "color": "green",  "text": "Online"     } } },
                { "type": "value", "options": { "offline":    { "color": "red",    "text": "Offline"    } } },
                { "type": "value", "options": { "stale":      { "color": "yellow", "text": "Instável"   } } },
                { "type": "value", "options": { "never_seen": { "color": "gray",   "text": "Nunca visto"} } }
              ]
            }]
          },
          {
            "matcher": { "id": "byName", "options": "cpu_percent" },
            "properties": [{ "id": "unit", "value": "percent" }, {
              "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": 0 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 }
              ]}
            }, { "id": "custom.displayMode", "value": "color-background" }]
          },
          {
            "matcher": { "id": "byName", "options": "ram_percent" },
            "properties": [{ "id": "unit", "value": "percent" }, {
              "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": 0 }, { "color": "yellow", "value": 85 }, { "color": "red", "value": 95 }
              ]}
            }, { "id": "custom.displayMode", "value": "color-background" }]
          }
        ]
      }
    },

    {
      "id": 20,
      "title": "Falhas DNS por Agente (últimas 24h)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT hostname, COUNT(*) AS falhas FROM dns_checks WHERE success = FALSE AND ts > NOW() - INTERVAL '24 hours' GROUP BY hostname ORDER BY falhas DESC LIMIT 20",
        "format": "table"
      }]
    },

    {
      "id": 21,
      "title": "Latência DNS Média por Domínio (última hora)",
      "type": "barchart",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT domain, ROUND(AVG(latency_ms)::numeric, 1) AS latencia_ms FROM dns_checks WHERE success = TRUE AND ts > NOW() - INTERVAL '1 hour' GROUP BY domain ORDER BY latencia_ms DESC",
        "format": "table"
      }]
    },

    {
      "id": 30,
      "title": "Alertas Recentes",
      "type": "table",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 7 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT ts AT TIME ZONE 'America/Sao_Paulo' AS horario, hostname, alert_type, severity, message, CASE WHEN resolved_at IS NULL THEN 'Aberto' ELSE 'Resolvido' END AS status FROM alerts_log ORDER BY ts DESC LIMIT 50",
        "format": "table"
      }],
      "fieldConfig": {
        "overrides": [{
          "matcher": { "id": "byName", "options": "severity" },
          "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
            "id": "mappings", "value": [
              { "type": "value", "options": { "critical": { "color": "red",    "text": "Crítico"  } } },
              { "type": "value", "options": { "warning":  { "color": "yellow", "text": "Aviso"    } } }
            ]
          }]
        }]
      }
    }

  ]
}

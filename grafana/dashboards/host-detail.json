{
  "title": "DNS Monitor — Detalhe do Host",
  "uid": "dns-host-detail",
  "tags": ["dns-monitor"],
  "timezone": "America/Sao_Paulo",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [{
      "name": "hostname",
      "type": "query",
      "datasource": { "uid": "timescaledb-dns" },
      "query": "SELECT hostname FROM agents ORDER BY hostname",
      "refresh": 2,
      "multi": false,
      "includeAll": false,
      "label": "Host"
    }]
  },
  "panels": [

    {
      "id": 1,
      "title": "Status do Agente",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT agent_status FROM v_agent_current_status WHERE hostname = '$hostname'",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "online":  { "color": "green",  "text": "Online"  } } },
            { "type": "value", "options": { "offline": { "color": "red",    "text": "Offline" } } },
            { "type": "value", "options": { "stale":   { "color": "yellow", "text": "Instável"} } }
          ]
        }
      }
    },

    {
      "id": 2,
      "title": "CPU Atual",
      "type": "gauge",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT cpu_percent FROM metrics_cpu WHERE hostname = '$hostname' ORDER BY ts DESC LIMIT 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 }
          ]}
        }
      }
    },

    {
      "id": 3,
      "title": "RAM Atual",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 3 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT ram_percent FROM metrics_ram WHERE hostname = '$hostname' ORDER BY ts DESC LIMIT 1",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 }, { "color": "yellow", "value": 85 }, { "color": "red", "value": 95 }
          ]}
        }
      }
    },

    {
      "id": 4,
      "title": "Serviço DNS",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 3 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT CONCAT(service_name, ' — ', CASE WHEN active THEN 'ativo' ELSE 'INATIVO' END) FROM dns_service_status WHERE hostname = '$hostname' ORDER BY ts DESC LIMIT 1",
        "format": "table"
      }]
    },

    {
      "id": 10,
      "title": "CPU % — últimas 24h",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 3, "w": 12, "h": 7 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT time_bucket('5 minutes', ts) AS time, AVG(cpu_percent) AS cpu_pct FROM metrics_cpu WHERE hostname = '$hostname' AND ts BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 }
          ]}
        }
      }
    },

    {
      "id": 11,
      "title": "RAM % — últimas 24h",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 3, "w": 12, "h": 7 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT time_bucket('5 minutes', ts) AS time, AVG(ram_percent) AS ram_pct FROM metrics_ram WHERE hostname = '$hostname' AND ts BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },

    {
      "id": 20,
      "title": "Uso de Disco por Partição",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 7 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT time_bucket('15 minutes', ts) AS time, mountpoint, AVG(disk_percent) AS pct FROM metrics_disk WHERE hostname = '$hostname' AND ts BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1, 2 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 }
          ]}
        }
      }
    },

    {
      "id": 21,
      "title": "I/O de Disco — bytes/s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 7 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT time_bucket('5 minutes', ts) AS time, (MAX(read_bytes) - MIN(read_bytes)) / 300.0 AS leitura_bytes_s, (MAX(write_bytes) - MIN(write_bytes)) / 300.0 AS escrita_bytes_s FROM metrics_io WHERE hostname = '$hostname' AND ts BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },

    {
      "id": 30,
      "title": "Latência DNS por Domínio",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 16, "h": 7 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT ts AS time, domain, latency_ms FROM dns_checks WHERE hostname = '$hostname' AND success = TRUE AND ts BETWEEN $__timeFrom() AND $__timeTo() ORDER BY ts",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": 0 }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 1000 }
          ]}
        }
      }
    },

    {
      "id": 31,
      "title": "Resultados DNS",
      "type": "table",
      "gridPos": { "x": 16, "y": 17, "w": 8, "h": 7 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT ts AT TIME ZONE 'America/Sao_Paulo' AS horario, domain, CASE WHEN success THEN 'OK' ELSE 'FALHA' END AS resultado, latency_ms, error_code FROM dns_checks WHERE hostname = '$hostname' AND ts BETWEEN $__timeFrom() AND $__timeTo() ORDER BY ts DESC LIMIT 100",
        "format": "table"
      }],
      "fieldConfig": {
        "overrides": [{
          "matcher": { "id": "byName", "options": "resultado" },
          "properties": [{ "id": "custom.displayMode", "value": "color-background" }, {
            "id": "mappings", "value": [
              { "type": "value", "options": { "OK":    { "color": "green" } } },
              { "type": "value", "options": { "FALHA": { "color": "red"   } } }
            ]
          }]
        }]
      }
    },

    {
      "id": 40,
      "title": "Load Average",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 6 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT time_bucket('5 minutes', ts) AS time, AVG(load_1m) AS load_1m, AVG(load_5m) AS load_5m, AVG(load_15m) AS load_15m FROM metrics_cpu WHERE hostname = '$hostname' AND ts BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }]
    },

    {
      "id": 41,
      "title": "Swap %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 6 },
      "datasource": { "uid": "timescaledb-dns" },
      "targets": [{
        "rawSql": "SELECT time_bucket('5 minutes', ts) AS time, AVG(swap_percent) AS swap_pct FROM metrics_ram WHERE hostname = '$hostname' AND ts BETWEEN $__timeFrom() AND $__timeTo() GROUP BY 1 ORDER BY 1",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    }

  ]
}

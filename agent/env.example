# /etc/dns-agent/env — segredos do agente
# Copie para /etc/dns-agent/env e preencha os valores
# Permissão recomendada: chmod 640 /etc/dns-agent/env

# Nome único desta máquina no sistema de monitoramento
AGENT_HOSTNAME=minha-maquina-01

# Token de autenticação — mesmo valor de AGENT_TOKEN no backend/.env
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
AGENT_TOKEN=TROQUE_POR_TOKEN_SEGURO

# URL completa do backend
AGENT_BACKEND=http://IP_DO_BACKEND:8000

# Default: normalize all text to LF on commit, auto-detect binary
* text=auto eol=lf

# Source / config — strict LF (executed on Linux)
*.sh        text eol=lf
*.py        text eol=lf
*.toml      text eol=lf
*.service   text eol=lf
*.sql       text eol=lf
*.conf      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.env*      text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf
Makefile    text eol=lf

# Web assets — LF for consistency across OSes
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.svg       text eol=lf

# Docs
*.md        text eol=lf
*.txt       text eol=lf
*.rst       text eol=lf

# Binary — never touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.zip       binary
*.tar.gz    binary
*.rar       binary
